// ═══════════════════════════════════════════════════════════════════
//  月度排行榜計算器 v1
//  讀取 Firestore reportLogs → 計算排名 → 寫入 rankings/{YYYY-MM}
//
//  前置作業（一次性）：
//  1. Apps Script 專案設定 → 變更 GCP 專案 → 填入 Firebase 的 GCP 專案編號
//  2. 如無法取得 OAuth，改用 SERVICE_ACCOUNT_KEY（詳見 getAccessToken_）
// ═══════════════════════════════════════════════════════════════════

const RANKING_CONFIG = {
  PROJECT_ID:       'taiwan-ramen-association',
  PLACEMENT_MIN:    20,   // 累計回報達此數才「出水」進入排名
  TRUST_THRESHOLD:  30,   // 信任分低於此值不列入抽獎池
  TOP_GUARANTEED:   3,    // 前幾名保證得獎
  DRAW_POOL_MAX:    50,   // 抽獎池最大人數
  DRAW_WINNERS:     3,    // 每月抽出幾名
};

const FS_BASE_ = `https://firestore.googleapis.com/v1/projects/${RANKING_CONFIG.PROJECT_ID}/databases/(default)/documents`;

function getAccessToken_() {
  // 若 Apps Script 已連結相同 GCP 專案，直接使用 OAuth token
  // 若出現 403，請改用 Service Account Key 存在 Script Properties
  const key = PropertiesService.getScriptProperties().getProperty('SA_KEY');
  if (key) {
    const sa  = JSON.parse(key);
    const jwt = makeJwt_(sa);
    const res = UrlFetchApp.fetch('https://oauth2.googleapis.com/token', {
      method: 'POST',
      payload: `grant_type=urn:ietf:params:oauth:grant-type:jwt-bearer&assertion=${jwt}`
    });
    return JSON.parse(res.getContentText()).access_token;
  }
  return ScriptApp.getOAuthToken();
}

function fsHeaders_() {
  return { 'Authorization': 'Bearer ' + getAccessToken_(), 'Content-Type': 'application/json' };
}

// ── Firestore 值轉換 ────────────────────────────────────────────────
function fsValueToJs_(val) {
  if (!val) return null;
  if ('stringValue'  in val) return val.stringValue;
  if ('integerValue' in val) return Number(val.integerValue);
  if ('doubleValue'  in val) return val.doubleValue;
  if ('booleanValue' in val) return val.booleanValue;
  if ('nullValue'    in val) return null;
  if ('arrayValue'   in val) return (val.arrayValue.values || []).map(fsValueToJs_);
  if ('mapValue'     in val) {
    const obj = {};
    for (const [k, v] of Object.entries(val.mapValue.fields || {})) obj[k] = fsValueToJs_(v);
    return obj;
  }
  return null;
}

function jsValueToFs_(val) {
  if (val === null || val === undefined) return { nullValue: null };
  if (typeof val === 'string')  return { stringValue: val };
  if (typeof val === 'boolean') return { booleanValue: val };
  if (typeof val === 'number')  return Number.isInteger(val) ? { integerValue: String(val) } : { doubleValue: val };
  if (Array.isArray(val)) return { arrayValue: { values: val.map(jsValueToFs_) } };
  if (typeof val === 'object') {
    const fields = {};
    for (const [k, v] of Object.entries(val)) fields[k] = jsValueToFs_(v);
    return { mapValue: { fields } };
  }
  return { nullValue: null };
}

function parseDoc_(doc) {
  const result = { _id: doc.name.split('/').pop() };
  for (const [k, v] of Object.entries(doc.fields || {})) result[k] = fsValueToJs_(v);
  return result;
}

// ── Firestore REST 操作 ─────────────────────────────────────────────
function fsGet_(collection, docId) {
  const resp = UrlFetchApp.fetch(
    `${FS_BASE_}/${collection}/${encodeURIComponent(docId)}`,
    { method: 'GET', headers: fsHeaders_(), muteHttpExceptions: true }
  );
  if (resp.getResponseCode() !== 200) return null;
  return parseDoc_(JSON.parse(resp.getContentText()));
}

function fsPatch_(collection, docId, data) {
  const fields = {};
  for (const [k, v] of Object.entries(data)) fields[k] = jsValueToFs_(v);
  UrlFetchApp.fetch(
    `${FS_BASE_}/${collection}/${encodeURIComponent(docId)}`,
    { method: 'PATCH', headers: fsHeaders_(), payload: JSON.stringify({ fields }), muteHttpExceptions: true }
  );
}

function fsRunQuery_(query) {
  const resp = UrlFetchApp.fetch(
    `${FS_BASE_}:runQuery`,
    { method: 'POST', headers: fsHeaders_(), payload: JSON.stringify({ structuredQuery: query }), muteHttpExceptions: true }
  );
  const results = JSON.parse(resp.getContentText());
  return results.filter(r => r.document).map(r => parseDoc_(r.document));
}

// ── 主函數：計算月排名 ──────────────────────────────────────────────
function calculateMonthlyRankings() {
  const now      = new Date();
  const year     = now.getFullYear();
  const month    = now.getMonth(); // 0-indexed
  const monthKey = `${year}-${String(month + 1).padStart(2, '0')}`;
  const startMs  = new Date(year, month, 1).getTime();
  const endMs    = now.getTime();

  Logger.log(`計算 ${monthKey} 排行榜`);

  // 1. 撈當月所有 reportLogs
  const logs = fsRunQuery_({
    from: [{ collectionId: 'reportLogs' }],
    where: {
      compositeFilter: {
        op: 'AND',
        filters: [
          { fieldFilter: { field: { fieldPath: 'ts' }, op: 'GREATER_THAN_OR_EQUAL', value: { integerValue: String(startMs) } } },
          { fieldFilter: { field: { fieldPath: 'ts' }, op: 'LESS_THAN_OR_EQUAL',    value: { integerValue: String(endMs)   } } }
        ]
      }
    }
  });

  Logger.log(`找到 ${logs.length} 筆 reportLogs`);
  if (!logs.length) { Logger.log('本月無回報，結束。'); return; }

  // 2. 依 uid 統計本月回報次數
  const monthCount = {};
  const uids = new Set();
  for (const log of logs) {
    if (!log.uid) continue;
    monthCount[log.uid] = (monthCount[log.uid] || 0) + 1;
    uids.add(log.uid);
  }

  // 3. 撈每個用戶的 users 文件
  const userData = {};
  for (const uid of uids) {
    const user = fsGet_('users', uid);
    if (user) userData[uid] = user;
  }

  // 4. 篩選「已出水」且本月有回報的用戶
  const eligible = [];
  for (const uid of uids) {
    const u          = userData[uid] || {};
    const totalCount = u.reportCount || 0;
    const trust      = (u.trustScore !== undefined && u.trustScore !== null) ? u.trustScore : 50;
    const placed     = totalCount >= RANKING_CONFIG.PLACEMENT_MIN;
    if (!placed) continue;
    eligible.push({
      uid,
      displayName: u.nickname || u.displayName || '匿名用戶',
      monthCount:  monthCount[uid] || 0,
      trustScore:  trust,
      totalCount,
    });
  }

  // 5. 依本月回報數排序（同分時信任分高者優先）
  eligible.sort((a, b) => b.monthCount - a.monthCount || b.trustScore - a.trustScore);

  // 6. 分配保證得獎 & 抽獎池
  const toEntry = u => ({ uid: u.uid, displayName: u.displayName, monthCount: u.monthCount });
  const top3 = eligible.slice(0, RANKING_CONFIG.TOP_GUARANTEED).map(toEntry);
  const drawPool = eligible
    .slice(RANKING_CONFIG.TOP_GUARANTEED, RANKING_CONFIG.DRAW_POOL_MAX)
    .filter(u => u.trustScore >= RANKING_CONFIG.TRUST_THRESHOLD)
    .map(toEntry);

  // 7. 寫入 Firestore rankings/{YYYY-MM}
  fsPatch_('rankings', monthKey, {
    monthKey,
    calculatedAt:  endMs,
    top3,
    drawPool,
    totalEligible: eligible.length,
    totalReports:  logs.length,
    drawnAt:       null,
    drawnWinners:  [],
  });

  Logger.log(`✅ 完成 — top3: ${top3.map(u => u.displayName).join('、')} ｜ 抽獎池: ${drawPool.length} 人`);
}

// ── 抽獎（管理員手動執行）──────────────────────────────────────────
function drawRankingWinners() {
  const now      = new Date();
  const monthKey = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
  const doc      = fsGet_('rankings', monthKey);

  if (!doc)         { Logger.log('找不到本月排行榜，請先執行 calculateMonthlyRankings()'); return; }
  if (doc.drawnAt)  { Logger.log('本月已完成抽獎：' + new Date(doc.drawnAt).toLocaleString()); return; }

  const pool = doc.drawPool || [];
  if (!pool.length) { Logger.log('抽獎池為空，無法抽獎'); return; }

  // Fisher–Yates shuffle
  const shuffled = [...pool];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  const winners = shuffled.slice(0, RANKING_CONFIG.DRAW_WINNERS);

  fsPatch_('rankings', monthKey, { drawnAt: Date.now(), drawnWinners: winners });
  Logger.log(`🎉 抽獎結果：${winners.map(w => w.displayName).join('、')}`);
}

// ── 設定每月自動觸發器（只需執行一次）─────────────────────────────
function setupMonthlyTrigger() {
  ScriptApp.getProjectTriggers()
    .filter(t => t.getHandlerFunction() === 'calculateMonthlyRankings')
    .forEach(t => ScriptApp.deleteTrigger(t));

  ScriptApp.newTrigger('calculateMonthlyRankings')
    .timeBased().onMonthDay(1).atHour(2).create();

  Logger.log('✅ 已設定每月 1 日凌晨 2:00 自動計算排行榜');
}

// ── JWT 工具（使用 Service Account 時才需要）───────────────────────
function makeJwt_(sa) {
  const now = Math.floor(Date.now() / 1000);
  const header  = Utilities.base64EncodeWebSafe(JSON.stringify({ alg: 'RS256', typ: 'JWT' }));
  const payload = Utilities.base64EncodeWebSafe(JSON.stringify({
    iss: sa.client_email,
    sub: sa.client_email,
    aud: 'https://oauth2.googleapis.com/token',
    iat: now,
    exp: now + 3600,
    scope: 'https://www.googleapis.com/auth/datastore',
  }));
  const sig = Utilities.base64EncodeWebSafe(
    Utilities.computeRsaSha256Signature(`${header}.${payload}`, sa.private_key)
  );
  return `${header}.${payload}.${sig}`;
}